<section class="container mx-auto p-6">
  <%= link_to "← Indietro", service_catalog_path(key: @key, folder: @folder), class: "text-sm text-blue-600 hover:underline" %>
  <h1 class="text-2xl font-semibold mt-2"><%= @item.title %></h1>
  <p class="text-gray-600"><%= @item.summary %></p>
  <pre class="mt-4 bg-gray-50 p-4 rounded-lg overflow-x-auto text-xs"><%= JSON.pretty_generate(@item.data) %></pre>
</section>
