<section class="container mx-auto p-6">
  <h1 class="text-2xl font-semibold mb-2"><%= @key %> — <%= @folder %></h1>
  <% if @items.blank? %>
    <p class="text-gray-500">Nessun elemento.</p>
  <% else %>
    <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      <% @items.each do |it| %>
        <li class="rounded-xl border p-4 bg-white">
          <h2 class="font-semibold"><%= it.title %></h2>
          <p class="text-sm text-gray-600"><%= it.summary %></p>
          <%= link_to "Apri", service_catalog_path(key: @key, folder: @folder, slug: it.slug), class: "text-blue-600 hover:underline text-sm" %>
        </li>
      <% end %>
    </ul>
  <% end %>
</section>
