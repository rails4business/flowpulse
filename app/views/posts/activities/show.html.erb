<section class="mx-auto w-full max-w-4xl px-4 py-8 space-y-4">
  <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Activity</p>
    <h1 class="mt-1 text-xl font-black text-slate-900"><%= @post.title.presence || @taxbranch&.slug_label %></h1>
    <p class="mt-1 text-sm text-slate-500">Attivita aperta per questo contenuto.</p>

    <div class="mt-4 grid grid-cols-1 md:grid-cols-3 gap-3 text-sm">
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
        <div class="text-[10px] uppercase tracking-wide text-slate-500">Stato</div>
        <div class="mt-1 font-semibold text-slate-800"><%= @activity.status %></div>
      </div>
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
        <div class="text-[10px] uppercase tracking-wide text-slate-500">Tipo</div>
        <div class="mt-1 font-semibold text-slate-800"><%= @activity.kind %></div>
      </div>
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
        <div class="text-[10px] uppercase tracking-wide text-slate-500">Data</div>
        <div class="mt-1 font-semibold text-slate-800"><%= l(@activity.occurred_at, format: :short) rescue @activity.occurred_at %></div>
      </div>
    </div>

    <div class="mt-4 flex flex-wrap items-center gap-2">
      <%= link_to "Apri contenuto", post_path(@post), class: "inline-flex items-center rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-white hover:brightness-110" %>
      <%= link_to "Torna dashboard", dashboard_home_path(tab: "academy"), class: "inline-flex items-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
    </div>
  </div>
</section>
