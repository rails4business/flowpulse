<% active_tab = params[:tab].to_s.presence_in(%w[insegnanti dolore integrato creator]) || "insegnanti" %>
<%
  page_theme_classes =
    case active_tab
    when "creator"
      { main: "bg-violet-50/40", panel: "border-violet-100 bg-violet-50/60", accent: "text-violet-600" }
    when "dolore"
      { main: "bg-rose-50/40", panel: "border-rose-100 bg-rose-50/60", accent: "text-rose-600" }
    when "integrato"
      { main: "bg-emerald-50/40", panel: "border-emerald-100 bg-emerald-50/60", accent: "text-emerald-600" }
    else
      { main: "bg-blue-50/40", panel: "border-blue-100 bg-blue-50/60", accent: "text-blue-600" }
    end
%>
<%
  header_title, header_desc, ambito_title, ambito_desc, ambito_icon, ambito_badge_text, ambito_badge_classes =
    case active_tab
    when "creator"
      [
        "Creator canale youtube <span class=\"#{page_theme_classes[:accent]}\">posturacorretta</span>",
        "Creator che realizzano contenuti video del modulo Igiene Posturale.",
        "Canale contenuti: YouTube",
        "In questa sezione trovi i creator video. Aprendo la card puoi vedere subito il video del canale YouTube.",
        "smart_display",
        "Canale YouTube attivo",
        "bg-red-50 text-red-700 border-red-200"
      ]
    when "dolore"
      [
        "Professionisti <span class=\"#{page_theme_classes[:accent]}\">Stop al dolore</span>",
        "Professionisti focalizzati su riduzione del dolore e recupero funzionale.",
        "Focus attivo: Stop al dolore",
        "Questa sezione raccoglie i professionisti con approccio prioritario su dolore, recupero e prevenzione ricadute.",
        "favorite",
        "Percorso dolore attivo",
        "bg-rose-50 text-rose-700 border-rose-200"
      ]
    when "integrato"
      [
        "Professionisti <span class=\"#{page_theme_classes[:accent]}\">Benessere Integrato</span>",
        "Professionisti disponibili a supportare il percorso integrato.",
        "Percorso attivo: Benessere integrato",
        "Questi professionisti supportano il percorso integrato e possono affiancare utenti e insegnanti.",
        "conversion_path",
        "Supporto percorso attivo",
        "bg-indigo-50 text-indigo-700 border-indigo-200"
      ]
    else
      [
        "Professionisti <span class=\"#{page_theme_classes[:accent]}\">disponibili</span>",
        "In questa fase gli insegnanti sono abilitati solo sul modulo Igiene Posturale.",
        "Modulo attivo: Igiene Posturale",
        "Questi insegnanti sono attivi per il modulo introduttivo. I moduli successivi verranno sbloccati progressivamente in base al percorso.",
        "check_circle",
        "Abilitazione verificata",
        "bg-emerald-50 text-emerald-700 border-emerald-200"
      ]
    end
%>
<main class="<%= page_theme_classes[:main] %>">
  <section class="max-w-[1200px] mx-auto px-6 py-12 space-y-8">
    <div class="flex flex-wrap gap-2">
