              <button type="button" class="rounded-lg px-2.5 py-1 text-[10px] font-bold uppercase tracking-wide text-slate-500 hover:bg-white/70">Centri</button>
              <button type="button" class="rounded-lg px-2.5 py-1 text-[10px] font-bold uppercase tracking-wide text-slate-500 hover:bg-white/70">Metodiche</button>
              <button type="button" class="rounded-lg px-2.5 py-1 text-[10px] font-bold uppercase tracking-wide text-slate-500 hover:bg-white/70">Recensioni</button>
            </div>
          </div>
        <% elsif active_tab == "integrato" %>
