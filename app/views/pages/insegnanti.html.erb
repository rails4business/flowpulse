</main>

<div id="teacherVideoModal" class="fixed inset-0 z-[80] hidden items-center justify-center bg-slate-900/70 p-4">
  <div class="w-full max-w-3xl rounded-2xl border border-slate-200 bg-white shadow-2xl overflow-hidden">
    <div class="flex items-center justify-between px-4 py-3 border-b border-slate-100">
      <h3 id="teacherVideoTitle" class="text-sm font-bold text-slate-800">Video insegnante</h3>
      <button id="teacherVideoCloseBtn" type="button" class="rounded-lg border border-slate-200 bg-white px-3 py-1.5 text-xs font-semibold text-slate-600 hover:bg-slate-50">Chiudi</button>
    </div>
    <div class="p-3">
      <div class="relative h-0 pb-[56.25%] overflow-hidden rounded-xl bg-slate-100">
        <iframe id="teacherVideoFrame" class="absolute top-0 left-0 h-full w-full" src="" title="Video insegnante" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
      </div>
    </div>
  </div>
</div>

<script>
  (() => {
    const modal = document.getElementById("teacherVideoModal");
    const frame = document.getElementById("teacherVideoFrame");
    const title = document.getElementById("teacherVideoTitle");
    const closeBtn = document.getElementById("teacherVideoCloseBtn");

    if (!modal || !frame || !title || !closeBtn) return;

    const closeModal = () => {
      modal.classList.add("hidden");
      modal.classList.remove("flex");
      frame.src = "";
      document.body.classList.remove("overflow-hidden");
    };

    document.querySelectorAll("[data-teacher-video]").forEach((card) => {
      card.addEventListener("click", () => {
        const src = card.getAttribute("data-teacher-video");
        const teacherName = card.getAttribute("data-teacher-name") || "Insegnante";
        if (!src) return;
        title.textContent = `Video di ${teacherName}`;
        frame.src = `${src}?autoplay=1&rel=0`;
        modal.classList.remove("hidden");
        modal.classList.add("flex");
        document.body.classList.add("overflow-hidden");
      });
    });

    closeBtn.addEventListener("click", closeModal);
    modal.addEventListener("click", (e) => {
      if (e.target === modal) closeModal();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeModal();
    });
  })();
</script>
