      <%= link_to "Stop al dolore", insegnanti_path(tab: "dolore"), class: "inline-flex items-center rounded-full border px-3 py-1 text-[11px] font-bold uppercase tracking-wide transition-colors #{active_tab == "dolore" ? "border-rose-500 bg-rose-50 text-rose-700" : "border-slate-200 bg-white text-slate-600 hover:bg-slate-50"}" %>
      <%= link_to "Benessere integrato", insegnanti_path(tab: "integrato"), class: "inline-flex items-center rounded-full border px-3 py-1 text-[11px] font-bold uppercase tracking-wide transition-colors #{active_tab == "integrato" ? "border-emerald-500 bg-emerald-50 text-emerald-700" : "border-slate-200 bg-white text-slate-600 hover:bg-slate-50"}" %>
