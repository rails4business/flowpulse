<h1 class="text-2xl font-semibold mb-4">Blog</h1>
<section class="space-y-3">
  <% @posts.each do |post| %>
    <article class="border rounded p-3">
      <h2 class="text-xl font-medium">
        <%= link_to post.title, flowpulse_blog_post_path(slug: post.slug) %>
      </h2>
      <% if post.description.present? %>
        <p class="opacity-80"><%= post.description %></p>
      <% end %>
      <div class="text-xs opacity-60 mt-1">
        <code><%= post.published_at&.to_date || "bozza" %></code>
      </div>
    </article>
  <% end %>
  <% if @posts.blank? %>
    <p class="italic opacity-70">Nessun post al momento.</p>
  <% end %>
</section>
