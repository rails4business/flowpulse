<% Array(course.lessons).each do |l| %>
  <%= link_to (l["title"].presence || l["slug"].to_s.humanize),
      flowpulse_onlinecourses_lesson_path(content_slug: course.content_slug, lesson_slug: l["slug"]) %>
<% end %>
<% crumbs = Array(@breadcrumb) %>
<%# fallback locale: se @course è nil, costruiscine uno minimo per non esplodere %>
<% course = @course || OpenStruct.new(
     title:        (@item&.title || params[:slug].to_s.humanize),
     description:  @item&.summary.to_s,
     content_slug: (@item&.slug || params[:slug]).to_s,
     cover_url:    nil,
     preparatory_courses: [],
     lessons: []
   ) %>
<nav class="mb-3 text-sm">
  <% crumbs.each_with_index do |bc, i| %>
    <% if bc[:path].present? %>
      <%= link_to bc[:name], bc[:path] %><%= " / " unless i == crumbs.size - 1 && crumbs.last[:path].nil? %>
    <% else %>
      <span><%= bc[:name] %></span>
    <% end %>
  <% end %>
</nav>
<header class="grid md:grid-cols-3 gap-4 mb-6 items-start">
  <div class="md:col-span-2">
    <h1 class="text-2xl font-semibold"><%= course.title %></h1>
    <% if course.description.present? %>
      <p class="mt-2 opacity-80"><%= course.description %></p>
    <% end %>
    <div class="mt-3 text-sm opacity-60">
      <code>slug:</code> <%= @item&.slug || params[:slug] %> ·
      <code>content_slug:</code> <%= course.content_slug %>
    </div>
  </div>
  <% if course.cover_url.present? %>
    <div class="md:justify-self-end">
      <img src="<%= course.cover_url %>" alt="Copertina <%= course.title %>" class="rounded-lg border max-h-48 object-contain">
    </div>
  <% end %>
</header>
<% if Array(course.preparatory_courses).present? %>
  <section class="mb-8">
    <h2 class="text-xl font-semibold mb-3">Prima di iniziare</h2>
    <ul class="grid md:grid-cols-2 gap-3">
      <% Array(course.preparatory_courses).each do |p| %>
        <li class="border rounded p-3">
          <h3 class="font-medium"><%= p["title"].presence || "Modulo preparatorio" %></h3>
          <% if p["description"].present? %>
            <p class="text-sm opacity-80"><%= p["description"] %></p>
          <% end %>
          <% if p["shared"] %>
            <div class="text-xs mt-2 inline-block px-2 py-0.5 rounded bg-gray-100">Condiviso</div>
          <% end %>
        </li>
      <% end %>
    </ul>
  </section>
<% end %>
<section>
  <h2 class="text-xl font-semibold mb-3">Lezioni</h2>
  <ol class="space-y-3">
    <% Array(course.lessons).each_with_index do |l, idx| %>
      <% anchor = "lesson-#{l['slug'].presence || ('l' + (idx+1).to_s)}" %>
      <li id="<%= anchor %>" class="border rounded p-3">
        <div class="flex items-start gap-3">
          <div class="text-lg font-semibold w-8 shrink-0"><%= idx + 1 %></div>
          <div class="flex-1">
            <h3 class="font-medium">
              <%= l["title"].presence || l["slug"].to_s.humanize.presence || "Lezione #{idx+1}" %>
              <% if l["chapter"] %><span class="ml-2 text-xs px-2 py-0.5 rounded bg-gray-100">Capitolo</span><% end %>
            </h3>
            <% if l["description"].present? %>
              <p class="text-sm opacity-80"><%= l["description"] %></p>
            <% end %>
            <div class="mt-2 flex flex-wrap gap-2 text-sm">
              <% if l["url_video"].present? %><a href="<%= l['url_video'] %>" target="_blank" rel="noopener" class="underline">Video</a><% end %>
              <% if l["url_pdf"].present? %><a href="<%= l['url_pdf'] %>" target="_blank" rel="noopener" class="underline">PDF</a><% end %>
              <a href="#<%= anchor %>" class="underline opacity-70">Permalink</a>
            </div>
          </div>
          <% if l["cover_url"].present? %>
            <img src="<%= l['cover_url'] %>" alt="" class="w-24 h-24 object-cover rounded border">
          <% end %>
        </div>
      </li>
    <% end %>
  </ol>
</section>
