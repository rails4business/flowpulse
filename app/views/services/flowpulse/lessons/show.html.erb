<% crumbs = Array(@breadcrumb) %>
<nav class="mb-3 text-sm">
  <% crumbs.each_with_index do |bc, i| %>
    <% if bc[:path].present? %>
      <%= link_to bc[:name], bc[:path] %><%= " / " unless i == crumbs.size - 1 && crumbs.last[:path].nil? %>
    <% else %><span><%= bc[:name] %></span><% end %>
  <% end %>
</nav>
<header class="mb-4">
  <h1 class="text-2xl font-semibold"><%= @lesson["title"].presence || @lesson["slug"].to_s.humanize %></h1>
  <% if @lesson["description"].present? %>
    <p class="opacity-80 mt-1"><%= @lesson["description"] %></p>
  <% end %>
</header>
<% if @post %>
  <article class="prose max-w-none">
    <h2 class="text-xl font-semibold mb-2"><%= @post.title %></h2>
    <% if @post.cover_url.present? %>
      <img src="<%= @post.cover_url %>" alt="" class="rounded border mb-3">
    <% end %>
    <%# Se generi HTML nel model (es. markdown -> html), usa body_html; altrimenti body %>
    <%= raw(@post.try(:body_html) || simple_format(@post.body.to_s)) %>
    <% if @post.video_url.present? %>
      <p class="mt-3"><a class="underline" href="<%= @post.video_url %>" target="_blank" rel="noopener">Guarda il video</a></p>
    <% end %>
  </article>
<% else %>
  <p class="italic opacity-70">Contenuto in arrivo…</p>
<% end %>
