<h1 class="text-xl font-semibold mb-4"><%= @brand.name %></h1>
<ul class="flex gap-2">
  <% @service_defs.each do |svc| %>
    <li>
      <%= link_to svc.key, service_index_path(key: svc.key), class: "px-3 py-1 rounded border" %>
    </li>
  <% end %>
</ul>
<% if @start_folder.present? %>
  <p class="mt-3 text-sm opacity-70">Cartella iniziale: <code><%= @start_folder %></code></p>
<% end %>
